# ==========================================
# Flask Backend Environment Variables (Render)
# ==========================================
SECRET_KEY="your-super-secret-key-here-change-in-production"
FLASK_APP=backend/app.py
FLASK_ENV=production

# Allowed CORS Origins (comma-separated for Render -> Vercel connection)
CORS_ORIGINS="http://localhost:3000,http://localhost:5173,https://your-vercel-app.vercel.app"

# Admin User Defaults
DEFAULT_ADMIN_EMAIL="admin@secureauth.io"
DEFAULT_ADMIN_PASSWORD="Admin@123_Change_Me"

# Email Configuration for OTP Verification (SMTP / Gmail)
MAIL_SERVER="smtp.gmail.com"
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME="your-email@gmail.com"
MAIL_PASSWORD="your-gmail-app-password"
MAIL_DEFAULT_SENDER="SecureAuth <your-email@gmail.com>"

# ==========================================
# Frontend Environment Variables (Vercel)
# ==========================================
# Point to your deployed Render API URL (e.g. https://your-backend.onrender.com/api)
# Leave blank on Vercel if utilizing vercel.json reverse proxying
VITE_API_BASE_URL="https://your-backend.onrender.com/api"
